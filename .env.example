# Supabase
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT
JWT_SECRET=your-random-secret-min-32-chars
JWT_EXPIRES_IN=24h

# EMQX Cloud Serverless
EMQX_API_URL=https://XXXX.ala.us-east-1.emqxsl.com:8443
EMQX_APP_ID=your-app-id
EMQX_APP_SECRET=your-app-secret
EMQX_BROKER_URL=wss://XXXX.ala.us-east-1.emqxsl.com:8084/mqtt
EMQX_AUTH_ID=password_based%3Abuilt_in_database

# Server MQTT (service account — create manually in EMQX console)
MQTT_SERVICE_USER=iotyk_server
MQTT_SERVICE_PASS=server-secret-password

# Encryption
AES_KEY=your-32-byte-hex-key-for-mqtt-passwords

# Server
PORT=3000
NODE_ENV=production
